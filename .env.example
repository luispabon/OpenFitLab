# =============================================================================
# OpenFitLab Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables without defaults are REQUIRED for the app to start.
# =============================================================================

# --- Database (defaults match docker-compose.yaml) ---
MARIADB_ROOT_PASSWORD=qsroot
MARIADB_DATABASE=openfitlab
MARIADB_USER=qs
MARIADB_PASSWORD=qspass

# --- Session ---
# Required. Generate with: openssl rand -hex 32
# Must be at least 32 characters. App will refuse to start if missing or too short.
SESSION_SECRET=

# --- Google OAuth ---
# From https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# From https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Apple OAuth ---
# From https://developer.apple.com → Certificates, Identifiers & Profiles → Keys / Identifiers
# APPLE_CLIENT_ID is the Services ID (not the Bundle ID)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the .p8 key content here with newlines replaced by \n
APPLE_PRIVATE_KEY=

# --- Facebook OAuth ---
# From https://developers.facebook.com → My Apps → <your app> → App Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- OAuth Callback Base URL ---
# The public base URL of your app (no trailing slash).
# Used to construct OAuth callback URLs, e.g. https://fit.example.com
# For local development: http://localhost:3000
OAUTH_CALLBACK_URL=http://localhost:3000

# --- Strava activity import (optional) ---
# From https://www.strava.com/settings/api — create an app and set Authorization Callback Domain
# to match your API host. Register this exact redirect URI in the app:
#   {OAUTH_CALLBACK_URL}/api/integrations/strava/callback
# Example local: http://localhost:3000/api/integrations/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Rate limiting (optional; all default if unset) ---
# API (all /api): max requests per window
# API_RATE_LIMIT_MAX=500
# API_RATE_LIMIT_WINDOW_MS=60000
# Auth (login initiation):
# AUTH_RATE_LIMIT_MAX=10
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# OAuth callbacks:
# AUTH_CALLBACK_RATE_LIMIT_MAX=20
# AUTH_CALLBACK_RATE_LIMIT_WINDOW_MS=900000
# Upload (POST /api/events):
# UPLOAD_RATE_LIMIT_MAX=50
# UPLOAD_RATE_LIMIT_WINDOW_MS=300000

# --- Frontend (Vite build-time; optional) ---
# Number of files per upload batch (1–10; backend accepts up to 10). Default: 5
# VITE_UPLOAD_CHUNK_SIZE=5

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX). Presence enables tracking.
# VITE_GA_MEASUREMENT_ID=

# --- Restic / GCS Backups ---
# Restic repository on GCS. Format: gs:<bucket-name>:/<path>
# Example: gs:openfitlab-backups:/prod
RESTIC_REPOSITORY=

# Strong passphrase used to encrypt backups. Store this safely — without it, backups are unrecoverable.
# Generate with: openssl rand -hex 32
RESTIC_PASSWORD=

# GCP project ID that owns the GCS bucket
GOOGLE_PROJECT_ID=

# Place your GCS service account JSON key at backup/secrets/gcs-key.json (gitignored)
