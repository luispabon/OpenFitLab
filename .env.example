# =============================================================================
# OpenFitLab Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables without defaults are REQUIRED for the app to start.
# =============================================================================

# --- Database (defaults match docker-compose.yaml) ---
MARIADB_ROOT_PASSWORD=qsroot
MARIADB_DATABASE=openfitlab
MARIADB_USER=qs
MARIADB_PASSWORD=qspass

# --- Session ---
# Required. Generate with: openssl rand -hex 32
# Must be at least 32 characters. App will refuse to start if missing or too short.
SESSION_SECRET=

# --- Google OAuth ---
# From https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# From https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth Callback Base URL ---
# The public base URL of your app (no trailing slash).
# Used to construct OAuth callback URLs, e.g. https://fit.example.com
# For local development: http://localhost:3000
OAUTH_CALLBACK_URL=http://localhost:3000
