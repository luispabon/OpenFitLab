{
  "name": "openfitlab-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "start:dev": "ng serve --configuration development --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "start:docker": "ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.docker.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "20.3.15",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "20.3.15",
    "@angular/compiler": "20.3.15",
    "@angular/core": "20.3.15",
    "@angular/forms": "20.3.15",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "20.3.15",
    "@angular/platform-browser-dynamic": "20.3.15",
    "@angular/router": "20.3.15",
    "@sports-alliance/sports-lib": "^6.1.14",
    "buffer": "^6.0.3",
    "kalmanjs": "^1.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.13",
    "@angular/cli": "20.3.13",
    "@angular/compiler-cli": "20.3.15",
    "typescript": "~5.8.0"
  }
}
