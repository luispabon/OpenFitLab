{
  "name": "openfitlab-api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\"",
    "test": "node --test",
    "test:unit": "node --test 'test/unit/**/*.test.js'",
    "test:coverage": "node --experimental-test-coverage --test 'test/unit/**/*.test.js'",
    "test:coverage:lcov": "mkdir -p coverage && node --experimental-test-coverage --test 'test/unit/**/*.test.js' --test-reporter=lcov --test-reporter-destination=coverage/lcov.info"
  },
  "dependencies": {
    "@sports-alliance/sports-lib": "^6.1.14",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1"
  }
}
