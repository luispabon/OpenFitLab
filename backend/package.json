{
  "name": "openfitlab-api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\"",
    "test": "SESSION_SECRET=test-secret-at-least-32-characters-long node --test",
    "test:unit": "SESSION_SECRET=test-secret-at-least-32-characters-long node --test 'test/unit/**/*.test.js'",
    "test:coverage": "SESSION_SECRET=test-secret-at-least-32-characters-long node --experimental-test-coverage --test 'test/unit/**/*.test.js'",
    "test:coverage:lcov": "mkdir -p coverage && SESSION_SECRET=test-secret-at-least-32-characters-long node --experimental-test-coverage --test 'test/unit/**/*.test.js' --test-reporter=lcov --test-reporter-destination=coverage/lcov.info"
  },
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.8",
    "@sports-alliance/sports-lib": "^9.0.0",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^4.6.0",
    "@xmldom/xmldom": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
